# Database
DB_DATABASE=daily_diary
DB_USERNAME=diary_user
DB_PASSWORD=your_password
DB_ROOT_PASSWORD=your_root_password

# GITHUB_REGISTRY
GITHUB_REPOSITORY_OWNER=your-github-username-must-be-lowercase

# Spring DataSource
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/daily_diary?serverTimezone=Asia/Seoul
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_DATASOURCE_USERNAME=diary_user
SPRING_DATASOURCE_PASSWORD=your_password

# JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JWT
JWT_SECRET=your-256-bit-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRY=1800000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# CORS
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
